---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../utils/date.js';

const { frontmatter } = Astro.props;
const { title, description, pubDate, number } = frontmatter;
---

<BaseLayout title={title} description={description}>
  <main class="wrap article">
    <p class="article__dateline">
      {number ? `Nº ${number} · ` : ''}{formatDate(pubDate)}
    </p>
    <h1 class="article__title">{title}</h1>
    {description && <p class="article__standfirst">{description}</p>}

    <div class="prose">
      <slot />
    </div>

    <p class="article__back"><a href="/">← Voltar ao arquivo</a></p>
  </main>
</BaseLayout>

<style>
  .article {
    max-width: var(--measure);
    margin-top: 3.5rem;
  }

  .article__dateline {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin: 0 0 1.1rem;
  }

  .article__title {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 2.9rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
  }

  .article__standfirst {
    font-family: var(--body);
    font-style: italic;
    font-size: 1.3rem;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0 0 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
  }

  .article__back {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 0.8rem;
  }
  .article__back a {
    color: var(--accent-deep);
    text-decoration: none;
  }
  .article__back a:hover { text-decoration: underline; }

  /* ---- Corpo do artigo (Markdown) ---- */
  .prose :global(p) {
    margin: 0 0 1.5rem;
  }
  .prose :global(h2) {
    font-family: var(--display);
    font-weight: 500;
    font-size: 1.6rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 3rem 0 1rem;
  }
  .prose :global(h3) {
    font-family: var(--display);
    font-weight: 500;
    font-size: 1.3rem;
    margin: 2.4rem 0 0.8rem;
  }
  .prose :global(a) {
    color: var(--accent-deep);
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    text-decoration-color: var(--accent);
  }
  .prose :global(blockquote) {
    margin: 2rem 0;
    padding: 0.2rem 0 0.2rem 1.5rem;
    border-left: 2px solid var(--accent);
    font-style: italic;
    color: var(--ink-soft);
  }
  .prose :global(blockquote p) { margin-bottom: 0.6rem; }
  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.4rem;
  }
  .prose :global(li) { margin-bottom: 0.5rem; }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--line);
    margin: 2.5rem 0;
  }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(em) { font-style: italic; }
</style>
