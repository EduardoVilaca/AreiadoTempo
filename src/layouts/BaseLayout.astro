---
const { title, description } = Astro.props;
const siteName = 'Areia do Tempo';
const pageTitle = title ? `${title} — ${siteName}` : `${siteName} — caderno de opinião`;
const pageDesc = description ?? 'Ensaios e opiniões sobre temas sociais, escritos para durar mais do que o ciclo de notícias.';
---

<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&family=Spectral:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        /* Calcário e pátina — areia, tempo e bronze envelhecido */
        --paper: #ece7dd;
        --paper-raised: #f3efe7;
        --ink: #211e18;
        --ink-soft: #5d564a;
        --line: #d4cdbf;
        --line-strong: #b8b0a0;
        --accent: #2c5f54;       /* verdigris: a cor do bronze que o tempo oxida */
        --accent-deep: #1e443c;

        --measure: 38rem;        /* largura de leitura confortável */
        --display: 'Fraunces', Georgia, serif;
        --body: 'Spectral', Georgia, serif;
        --mono: 'IBM Plex Mono', 'SFMono-Regular', monospace;
      }

      * { box-sizing: border-box; }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--body);
        font-size: 1.125rem;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a { color: inherit; }

      ::selection {
        background: var(--accent);
        color: var(--paper-raised);
      }

      /* ---- Estrutura de página ---- */
      .wrap {
        width: 100%;
        max-width: 64rem;
        margin: 0 auto;
        padding: 0 1.75rem;
      }

      /* ---- Cabeçalho fino ---- */
      .site-head {
        border-bottom: 1px solid var(--line);
      }
      .site-head__inner {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.4rem 0;
      }
      .wordmark {
        font-family: var(--display);
        font-weight: 500;
        font-size: 1.35rem;
        letter-spacing: -0.01em;
        text-decoration: none;
        color: var(--ink);
        line-height: 1;
      }
      .wordmark:hover { color: var(--accent-deep); }
      .site-nav {
        display: flex;
        gap: 1.5rem;
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .site-nav a {
        text-decoration: none;
        color: var(--ink-soft);
        padding-bottom: 2px;
        border-bottom: 1px solid transparent;
        transition: color 0.15s, border-color 0.15s;
      }
      .site-nav a:hover {
        color: var(--accent-deep);
        border-color: var(--accent);
      }

      /* ---- Rodapé ---- */
      .site-foot {
        margin-top: 5rem;
        border-top: 1px solid var(--line);
      }
      .site-foot__inner {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
        justify-content: space-between;
        padding: 2rem 0 3rem;
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        color: var(--ink-soft);
      }
      .site-foot__inner a {
        color: var(--accent-deep);
        text-decoration: none;
      }

      /* ---- Elementos editoriais reutilizáveis ---- */
      .eyebrow {
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-deep);
      }

      @media (max-width: 540px) {
        body { font-size: 1.06rem; }
        .site-head__inner { flex-direction: column; gap: 0.7rem; align-items: flex-start; }
      }

      @media (prefers-reduced-motion: reduce) {
        * { transition: none !important; animation: none !important; }
      }
    </style>
  </head>

  <body>
    <header class="site-head">
      <div class="wrap site-head__inner">
        <a class="wordmark" href="/">Areia&nbsp;do&nbsp;Tempo</a>
        <nav class="site-nav">
          <a href="/arquivo">Arquivo</a>
          <a href="/sobre">Sobre</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-foot">
      <div class="wrap site-foot__inner">
        <span>© {new Date().getFullYear()} Areia do Tempo</span>
        <span>areiadotempo.pt</span>
      </div>
    </footer>
  </body>
</html>
