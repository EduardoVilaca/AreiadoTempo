---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDateShort } from '../utils/date.js';

// Astro 6: usar import.meta.glob (Astro.glob foi removido).
const modules = import.meta.glob('./blog/*.md', { eager: true });

const allPosts = Object.values(modules)
  .map((m) => ({ url: m.url, ...m.frontmatter }))
  .sort((a, b) =>
  Number(b.caderno) - Number(a.caderno) ||   // dossiers: recente → antigo
  Number(a.number) - Number(b.number)        // capítulos: primeiro → último
);
//  .sort((a, b) => Number(a.number) - Number(b.number));

// Caminho B: a entrada mostra só os mais recentes; o arquivo tem tudo
const cadernoAtual = allPosts.length
  ? allPosts.filter((p) => p.caderno === allPosts[0].caderno)
  : [];
const posts = cadernoAtual;
const haMais = allPosts.length > cadernoAtual.length;
const cadernoTitulo = posts[0]?.cadernoTitulo ?? '';

---

<BaseLayout>
  <main class="wrap">
    <section class="hero">
      <p class="eyebrow">Caderno de opinião</p>
      <h1 class="hero__thesis">
        O que se diz no calor do dia assenta, com o tempo, como areia.
      </h1>
      <p class="hero__lede">
        Ensaios sobre os temas que nos unem e nos dividem — escritos com vagar,
        para serem lidos depois de a poeira baixar.
      </p>
    </section>

    <section class="index" aria-label="Ensaios">
      {cadernoTitulo && <h2 class="index__caderno">{cadernoTitulo}</h2>}
      <ol class="index__list">
        {posts.map((post) => (
          <li class="entry">
            <a class="entry__link" href={post.url}>
              <p class="entry__meta">Nº {post.number} · {formatDateShort(post.pubDate)}</p>
              <h2 class="entry__title">{post.title}</h2>
              <p class="entry__dek">{post.description}</p>
            </a>
          </li>
        ))}
      </ol>
      {haMais && (
        <p class="index__more">
          <a href="/arquivo">Ver todos os ensaios no arquivo →</a>
        </p>
      )}
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    max-width: 44rem;
    padding: 4.5rem 0 3.5rem;
  }
  .hero .eyebrow { margin: 0 0 1.5rem; }
  .hero__thesis {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(2.1rem, 6vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    text-wrap: balance;
  }
  .hero__lede {
    font-family: var(--body);
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    max-width: 34rem;
  }

  .index {
    border-top: 1px solid var(--line-strong);
  }
  .index__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .entry { border-bottom: 1px solid var(--line); }
  .entry__link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 2.2rem 0;
    transition: background 0.15s;
  }
  .entry__link:hover { background: var(--paper-raised); }
  .entry__link:hover .entry__title { color: var(--accent-deep); }
  .entry__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  .entry__meta {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin: 0 0 0.6rem;
  }
  .entry__title {
    font-family: var(--display);
    font-weight: 500;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    line-height: 1.12;
    letter-spacing: -0.015em;
    margin: 0 0 0.6rem;
    transition: color 0.15s;
  }
  .entry__dek {
    font-family: var(--body);
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    max-width: 42rem;
  }
  .index__more {
    margin: 2.2rem 0 0;
    font-family: var(--mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
  }
  .index__more a {
    color: var(--accent-deep);
    text-decoration: none;
  }
  .index__more a:hover { text-decoration: underline; }
    .index__caderno {
      font-family: var(--mono);
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-deep);
      margin: 0 0 1.5rem;
      padding-bottom: 1.2rem;
      border-bottom: 1px solid var(--line-strong);
    }
</style>
